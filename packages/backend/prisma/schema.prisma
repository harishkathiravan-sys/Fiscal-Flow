generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ───────────────────────────

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  name            String
  avatar          String?
  role            Role     @default(ADMIN)
  emailVerified   Boolean  @default(false)
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships       Membership[]
  documents         Document[]
  journalEntries    JournalEntry[]
  comments          Comment[]
  refreshTokens     RefreshToken[]
  verificationTokens VerificationToken[]
  passwordResets    PasswordReset[]
  clients           Client[]

  @@map("users")
}

enum Role {
  ADMIN
  ACCOUNTANT
  CLIENT
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  type      VerificationType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// ─── Clients ────────────────────────────────

model Client {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  country        String   @default("India")
  gstin          String?
  pan            String?
  tan            String?
  companyName    String?
  industry       String?
  website        String?
  notes          String?
  isActive       Boolean  @default(true)
  organizationId String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  user         User          @relation(fields: [createdBy], references: [id])
  tags         ClientTag[]
  contacts     ClientContact[]

  @@index([organizationId])
  @@map("clients")
}

model ClientContact {
  id       String  @id @default(uuid())
  name     String
  email    String?
  phone    String?
  role     String?
  isPrimary Boolean @default(false)
  clientId String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_contacts")
}

model ClientTag {
  id       String @id @default(uuid())
  name     String
  color    String @default("#10b981")
  clientId String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, name])
  @@map("client_tags")
}

// ─── Organizations ──────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  taxId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       Membership[]
  chartOfAccounts   Account[]
  journalEntries    JournalEntry[]
  documents         Document[]
  documentFolders   DocumentFolder[]
  reports           Report[]
  clients           Client[]

  @@map("organizations")
}

model Membership {
  id             String   @id @default(uuid())
  role           Role     @default(ADMIN)
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("memberships")
}

// ─── Accounting ─────────────────────────────

model Account {
  id             String    @id @default(uuid())
  code           String
  name           String
  type           AccountType
  subType        String?
  description    String?
  isArchived     Boolean   @default(false)
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id])
  journalLines  JournalLine[]
  parentAccount Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  childAccounts Account[]     @relation("AccountHierarchy")
  parentId      String?

  @@unique([organizationId, code])
  @@map("accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id             String        @id @default(uuid())
  entryDate      DateTime
  description    String
  reference      String?
  status         JournalStatus @default(DRAFT)
  organizationId String
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [createdBy], references: [id])
  lines        JournalLine[]
  document     Document?    @relation(fields: [documentId], references: [id])
  documentId   String?

  @@map("journal_entries")
}

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

model JournalLine {
  id             String   @id @default(uuid())
  debit          Decimal  @default(0) @db.Decimal(12, 2)
  credit         Decimal  @default(0) @db.Decimal(12, 2)
  description    String?
  journalEntryId String
  accountId      String
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  @@map("journal_lines")
}

// ─── Documents & OCR ────────────────────────

model Document {
  id             String       @id @default(uuid())
  name           String
  fileName       String
  fileType       String
  fileSize       Int
  mimeType       String
  s3Key          String
  s3Bucket       String
  type           DocumentType @default(OTHER)
  description    String?
  tags           String[]
  ocrStatus      OcrStatus    @default(PENDING)
  ocrData        Json?
  isArchived     Boolean      @default(false)
  folderId       String?
  organizationId String
  uploadedBy     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  user         User            @relation(fields: [uploadedBy], references: [id])
  folder         DocumentFolder? @relation(fields: [folderId], references: [id])
  versions       DocumentVersion[]
  ocrExtraction  OcrExtraction?
  journalEntry   JournalEntry[]
  comments       Comment[]

  @@index([organizationId])
  @@index([folderId])
  @@map("documents")
}

model OcrExtraction {
  id             String    @id @default(uuid())
  documentId     String    @unique
  status         OcrStatus @default(PENDING)
  rawText        String?
  vendor         String?
  invoiceNumber  String?
  invoiceDate    DateTime?
  gstin          String?
  subtotal       Decimal?  @db.Decimal(12, 2)
  cgst           Decimal?  @db.Decimal(12, 2)
  sgst           Decimal?  @db.Decimal(12, 2)
  igst           Decimal?  @db.Decimal(12, 2)
  total          Decimal?  @db.Decimal(12, 2)
  hsnCode        String?
  confidence     Json?
  errorMessage   String?
  isCorrected    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("ocr_extractions")
}

model DocumentFolder {
  id             String   @id @default(uuid())
  name           String
  parentId       String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent       DocumentFolder? @relation("FolderHierarchy", fields: [parentId], references: [id])
  children     DocumentFolder[] @relation("FolderHierarchy")
  documents    Document[]
  organization Organization  @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name, parentId])
  @@index([organizationId])
  @@map("document_folders")
}

model DocumentVersion {
  id         String   @id @default(uuid())
  version    Int
  fileName   String
  fileSize   Int
  s3Key      String
  comment    String?
  documentId String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_versions")
}

enum DocumentType {
  INVOICE
  RECEIPT
  BILL
  PURCHASE_ORDER
  BANK_STATEMENT
  GST_DOCUMENT
  OTHER
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Reports ────────────────────────────────

model Report {
  id             String     @id @default(uuid())
  type           ReportType
  title          String
  data           Json
  periodStart    DateTime
  periodEnd      DateTime
  organizationId String
  generatedBy    String
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("reports")
}

enum ReportType {
  INCOME_STATEMENT
  BALANCE_SHEET
  CASH_FLOW
  TRIAL_BALANCE
  GENERAL_LEDGER
}

// ─── Comments ───────────────────────────────

model Comment {
  id         String   @id @default(uuid())
  content    String
  documentId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("comments")
}
