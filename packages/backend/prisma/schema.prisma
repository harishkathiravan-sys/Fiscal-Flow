generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ───────────────────────────

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  name            String
  avatar          String?
  role            Role     @default(ADMIN)
  emailVerified   Boolean  @default(false)
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  memberships       Membership[]
  documents         Document[]
  journalEntries    JournalEntry[]
  comments          Comment[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  expenses          Expense[]
  bankImports       BankImport[]
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]
  verificationTokens VerificationToken[]
  passwordResets    PasswordReset[]
  clients           Client[]

  @@map("users")
}

enum Role {
  ADMIN
  ACCOUNTANT
  CLIENT
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  type      VerificationType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("verification_tokens")
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// ─── Clients ────────────────────────────────

model Client {
  id             String   @id @default(uuid())
  name           String
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  pincode        String?
  country        String   @default("India")
  gstin          String?
  pan            String?
  tan            String?
  companyName    String?
  industry       String?
  website        String?
  notes          String?
  isActive       Boolean  @default(true)
  organizationId String
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id])
  user         User          @relation(fields: [createdBy], references: [id])
  tags         ClientTag[]
  contacts     ClientContact[]
  invoices     Invoice[]

  @@index([organizationId])
  @@map("clients")
}

model ClientContact {
  id       String  @id @default(uuid())
  name     String
  email    String?
  phone    String?
  role     String?
  isPrimary Boolean @default(false)
  clientId String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@map("client_contacts")
}

model ClientTag {
  id       String @id @default(uuid())
  name     String
  color    String @default("#10b981")
  clientId String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, name])
  @@map("client_tags")
}

// ─── Organizations ──────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  taxId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships       Membership[]
  chartOfAccounts   Account[]
  journalEntries    JournalEntry[]
  documents         Document[]
  documentFolders   DocumentFolder[]
  reports           Report[]
  clients           Client[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  expenses          Expense[]
  bankTransactions  BankTransaction[]
  bankImports       BankImport[]
  auditLogs         AuditLog[]
  aiInsights        AiInsight[]

  @@map("organizations")
}

model Membership {
  id             String   @id @default(uuid())
  role           Role     @default(ADMIN)
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId])
  @@map("memberships")
}

// ─── Accounting ─────────────────────────────

model Account {
  id             String    @id @default(uuid())
  code           String
  name           String
  type           AccountType
  subType        String?
  description    String?
  isArchived     Boolean   @default(false)
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id])
  journalLines  JournalLine[]
  parentAccount Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  childAccounts Account[]     @relation("AccountHierarchy")
  parentId      String?

  @@unique([organizationId, code])
  @@map("accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

model JournalEntry {
  id             String        @id @default(uuid())
  entryDate      DateTime
  description    String
  reference      String?
  status         JournalStatus @default(DRAFT)
  organizationId String
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [createdBy], references: [id])
  lines        JournalLine[]
  document     Document?    @relation(fields: [documentId], references: [id])
  documentId   String?

  @@map("journal_entries")
}

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

model JournalLine {
  id             String   @id @default(uuid())
  debit          Decimal  @default(0) @db.Decimal(12, 2)
  credit         Decimal  @default(0) @db.Decimal(12, 2)
  description    String?
  journalEntryId String
  accountId      String
  createdAt      DateTime @default(now())

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id])
  account      Account      @relation(fields: [accountId], references: [id])

  @@map("journal_lines")
}

// ─── Documents & OCR ────────────────────────

model Document {
  id             String       @id @default(uuid())
  name           String
  fileName       String
  fileType       String
  fileSize       Int
  mimeType       String
  s3Key          String
  s3Bucket       String
  type           DocumentType @default(OTHER)
  description    String?
  tags           String[]
  ocrStatus      OcrStatus    @default(PENDING)
  ocrData        Json?
  isArchived     Boolean      @default(false)
  folderId       String?
  organizationId String
  uploadedBy     String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id])
  user         User            @relation(fields: [uploadedBy], references: [id])
  folder         DocumentFolder? @relation(fields: [folderId], references: [id])
  versions       DocumentVersion[]
  ocrExtraction  OcrExtraction?
  journalEntry   JournalEntry[]
  comments       Comment[]

  @@index([organizationId])
  @@index([folderId])
  @@map("documents")
}

model OcrExtraction {
  id             String    @id @default(uuid())
  documentId     String    @unique
  status         OcrStatus @default(PENDING)
  rawText        String?
  vendor         String?
  invoiceNumber  String?
  invoiceDate    DateTime?
  gstin          String?
  subtotal       Decimal?  @db.Decimal(12, 2)
  cgst           Decimal?  @db.Decimal(12, 2)
  sgst           Decimal?  @db.Decimal(12, 2)
  igst           Decimal?  @db.Decimal(12, 2)
  total          Decimal?  @db.Decimal(12, 2)
  hsnCode        String?
  confidence     Json?
  errorMessage   String?
  isCorrected    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("ocr_extractions")
}

model DocumentFolder {
  id             String   @id @default(uuid())
  name           String
  parentId       String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  parent       DocumentFolder? @relation("FolderHierarchy", fields: [parentId], references: [id])
  children     DocumentFolder[] @relation("FolderHierarchy")
  documents    Document[]
  organization Organization  @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name, parentId])
  @@index([organizationId])
  @@map("document_folders")
}

model DocumentVersion {
  id         String   @id @default(uuid())
  version    Int
  fileName   String
  fileSize   Int
  s3Key      String
  comment    String?
  documentId String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_versions")
}

enum DocumentType {
  INVOICE
  RECEIPT
  BILL
  PURCHASE_ORDER
  BANK_STATEMENT
  GST_DOCUMENT
  OTHER
}

enum OcrStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── Invoices ───────────────────────────────

model Invoice {
  id               String         @id @default(uuid())
  invoiceNumber    String
  status           InvoiceStatus  @default(PENDING)
  clientId         String
  issueDate        DateTime       @default(now())
  dueDate          DateTime
  subtotal         Decimal        @db.Decimal(12, 2)
  discountPercent  Decimal?       @db.Decimal(5, 2) @default(0)
  discountAmount   Decimal        @db.Decimal(12, 2) @default(0)
  cgst             Decimal        @db.Decimal(12, 2) @default(0)
  sgst             Decimal        @db.Decimal(12, 2) @default(0)
  igst             Decimal        @db.Decimal(12, 2) @default(0)
  totalTax         Decimal        @db.Decimal(12, 2) @default(0)
  total            Decimal        @db.Decimal(12, 2)
  amountPaid       Decimal        @db.Decimal(12, 2) @default(0)
  balanceDue       Decimal        @db.Decimal(12, 2)
  notes            String?
  terms            String?
  gstin            String?
  pan              String?
  billingAddress   String?
  shippingAddress  String?
  reference        String?
  recurring        Boolean        @default(false)
  recurringId      String?
  organizationId   String
  createdBy        String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id])
  user         User               @relation(fields: [createdBy], references: [id])
  client       Client             @relation(fields: [clientId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]
  recurringInvoice RecurringInvoice? @relation(fields: [recurringId], references: [id])

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([clientId])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  description String
  hsnCode     String?
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  gstRate     Decimal @default(0) @db.Decimal(5, 2)
  amount      Decimal @db.Decimal(12, 2)
  invoiceId   String

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id          String        @id @default(uuid())
  amount      Decimal       @db.Decimal(12, 2)
  paymentDate DateTime      @default(now())
  method      String?
  reference   String?
  notes       String?
  invoiceId   String
  createdAt   DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

model RecurringInvoice {
  id           String          @id @default(uuid())
  frequency    RecurringFrequency
  startDate    DateTime
  endDate      DateTime?
  nextRunDate  DateTime
  isActive     Boolean         @default(true)
  templateData Json
  organizationId String
  createdBy    String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [createdBy], references: [id])
  invoices     Invoice[]

  @@map("recurring_invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  PARTIAL
  CANCELLED
}

enum RecurringFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ─── Expenses ───────────────────────────────

model Expense {
  id             String         @id @default(uuid())
  description    String
  amount         Decimal        @db.Decimal(12, 2)
  date           DateTime       @default(now())
  category       ExpenseCategory @default(MISCELLANEOUS)
  vendor         String?
  paymentMethod  String?
  reference      String?
  notes          String?
  receiptUrl     String?
  gstAmount      Decimal?       @db.Decimal(12, 2)
  isRecurring    Boolean        @default(false)
  isDeductable   Boolean        @default(true)
  organizationId String
  createdBy      String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [createdBy], references: [id])

  @@index([organizationId])
  @@index([category])
  @@index([date])
  @@map("expenses")
}

enum ExpenseCategory {
  OFFICE_SUPPLIES
  TRAVEL
  MEALS
  SOFTWARE
  PROFESSIONAL_SERVICES
  RENT
  UTILITIES
  MARKETING
  INSURANCE
  TAXES
  PAYROLL
  EQUIPMENT
  MAINTENANCE
  LEGAL
  TELECOMMUNICATIONS
  MISCELLANEOUS
}

// ─── Bank Statements ────────────────────────

model BankTransaction {
  id               String            @id @default(uuid())
  transactionDate  DateTime
  description      String
  amount           Decimal           @db.Decimal(12, 2)
  balance          Decimal?          @db.Decimal(12, 2)
  category         TransactionCategory @default(UNCATEGORIZED)
  vendor           String?
  isSubscription   Boolean           @default(false)
  subscriptionName String?
  reconciled       Boolean           @default(false)
  matchedExpenseId String?
  matchedInvoiceId String?
  organizationId   String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([category])
  @@index([transactionDate])
  @@map("bank_transactions")
}

enum TransactionCategory {
  UNCATEGORIZED
  INCOME
  EXPENSE
  TRANSFER
  FEE
  INTEREST
  SUBSCRIPTION
  PAYROLL
  TAX
  LOAN
}

model BankImport {
  id             String   @id @default(uuid())
  fileName       String
  fileType       String
  rowCount       Int      @default(0)
  matchedCount   Int      @default(0)
  organizationId String
  importedBy     String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [importedBy], references: [id])

  @@map("bank_imports")
}

// ─── Audit & Activity Logs ──────────────────

model AuditLog {
  id             String   @id @default(uuid())
  action         String
  entityType     String
  entityId       String?
  changes        Json?
  ipAddress      String?
  userAgent      String?
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id             String   @id @default(uuid())
  type           String
  title          String
  description    String?
  metadata       Json?
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([createdAt])
  @@map("activity_logs")
}

model AiInsight {
  id             String       @id @default(uuid())
  type           InsightType
  title          String
  description    String
  severity       InsightSeverity @default(INFO)
  data           Json?
  isRead         Boolean      @default(false)
  isDismissed    Boolean      @default(false)
  organizationId String
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([type])
  @@map("ai_insights")
}

enum InsightType {
  CASH_FLOW_PREDICTION
  LATE_PAYMENT
  EXPENSE_ANOMALY
  DUPLICATE_INVOICE
  FINANCIAL_HEALTH
  REVENUE_TREND
  SUBSCRIPTION_DETECTED
  RECONCILIATION_SUGGESTION
}

enum InsightSeverity {
  INFO
  WARNING
  CRITICAL
}

// ─── Reports ────────────────────────────────

model Report {
  id             String     @id @default(uuid())
  type           ReportType
  title          String
  data           Json
  periodStart    DateTime
  periodEnd      DateTime
  organizationId String
  generatedBy    String
  createdAt      DateTime   @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("reports")
}

enum ReportType {
  INCOME_STATEMENT
  BALANCE_SHEET
  CASH_FLOW
  TRIAL_BALANCE
  GENERAL_LEDGER
}

// ─── Comments ───────────────────────────────

model Comment {
  id         String   @id @default(uuid())
  content    String
  documentId String
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("comments")
}
